<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Messanger.Views.MapPage"
             Title="Standorte"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <Grid RowDefinitions="*,Auto" BackgroundColor="{DynamicResource BackgroundColor}">

        <!-- OpenStreetMap in WebView -->
        <WebView Grid.Row="0" 
                 x:Name="MapWebView" />

        <!-- Control Panel -->
        <Frame Grid.Row="1" Padding="12" Margin="10,5,10,10" 
               BackgroundColor="{DynamicResource SurfaceColor}"
               CornerRadius="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Label Grid.Column="0"
                       Text="Meinen Standort teilen"
                       VerticalOptions="Center"
                       FontSize="16"
                       TextColor="{DynamicResource TextColor}" />
                <Switch Grid.Column="1"
                        x:Name="SharingSwitch"
                        Toggled="OnSharingToggled"
                        OnColor="#34C759"
                        ThumbColor="White" />
            </Grid>
        </Frame>
    </Grid>
</ContentPage>
