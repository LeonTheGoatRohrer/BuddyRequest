<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Messanger.Views.RegistrationPage"
             Title="Registrierung">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Neuen Benutzer registrieren"
             FontSize="24"
             HorizontalOptions="Center"
             Margin="0,0,0,10" />

            <Label Text="Benutzername" />
            <Entry Placeholder="Benutzername"
             Text="{Binding Username}" />

            <Label Text="Email" />
            <Entry Placeholder="Email"
             Text="{Binding Email}" />

            <Label Text="Passwort" />
            <Entry Placeholder="Passwort"
             IsPassword="True"
             Text="{Binding Password}" />

            <Label Text="Passwort wiederholen" />
            <Entry Placeholder="Passwort wiederholen"
             IsPassword="True"
             Text="{Binding PasswordRepeat}" />

            <Label Text="{Binding Message}"
             TextColor="blue" />
            

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                         IsVisible="{Binding IsBusy}" />

            <Button Text="Registrieren"
              Command="{Binding RegisterCommand}" />

            <Button Text="Zurück"
              Clicked="OnBackToLoginClicked"
              Margin="0,10,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
