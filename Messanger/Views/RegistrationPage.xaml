<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Messanger.Views.RegistrationPage"
             Title="Registrierung">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Avatar Vorschau -->
            <Border StrokeThickness="2"
                    Stroke="#007AFF"
                    WidthRequest="100"
                    HeightRequest="100"
                    HorizontalOptions="Center"
                    Margin="0,10,0,5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="50"/>
                </Border.StrokeShape>
                <Image Source="{Binding Username, StringFormat='https://api.dicebear.com/7.x/avataaars/svg?seed={0}'}" 
                       Aspect="AspectFill"/>
            </Border>
            
            <Label Text="Dein Avatar wird automatisch generiert"
                   FontSize="12"
                   TextColor="Gray"
                   HorizontalOptions="Center"
                   Margin="0,0,0,10" />

            <Label Text="Neuen Benutzer registrieren"
             FontSize="24"
             HorizontalOptions="Center"
             Margin="0,0,0,10" />

            <Label Text="Benutzername" />
            <Entry Placeholder="Benutzername"
             Text="{Binding Username}" />

            <Label Text="Email" />
            <Entry Placeholder="Email"
             Text="{Binding Email}" />

            <Label Text="Passwort" />
            <Entry Placeholder="Passwort"
             IsPassword="True"
             Text="{Binding Password}" />

            <Label Text="Passwort wiederholen" />
            <Entry Placeholder="Passwort wiederholen"
             IsPassword="True"
             Text="{Binding PasswordRepeat}" />

            <Label Text="{Binding Message}"
             TextColor="Blue" />
            

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                         IsVisible="{Binding IsBusy}" />

            <Button Text="Registrieren"
              Command="{Binding RegisterCommand}"
              BackgroundColor="#34C759"
              TextColor="White"
              CornerRadius="10"
              HeightRequest="50" />

            <Button Text="Zurück zum Login"
              Clicked="OnBackToLoginClicked"
              Margin="0,10,0,0"
              BackgroundColor="Transparent"
              TextColor="#007AFF" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
