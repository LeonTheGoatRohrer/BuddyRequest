<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Messanger.ViewModels"
             x:Class="Messanger.Views.RequestsPage"
             Title="Requests"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource BackgroundDark}}">
    <ContentPage.BindingContext>
        <vm:RequestsViewModel />
    </ContentPage.BindingContext>
    
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Header Section -->
            <Grid RowDefinitions="Auto,Auto" Padding="8,16">
                <Label Grid.Row="0"
                       Text="📬 Requests"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                       HorizontalOptions="Start" />
                <Label Grid.Row="1"
                       Text="Verwalte deine Anfragen und Wünsche"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                       HorizontalOptions="Start"
                       Margin="0,4,0,0" />
            </Grid>

            <!-- Status Message -->
            <Frame IsVisible="{Binding StatusMessage, Converter={StaticResource StringToBoolConverter}}"
                   BackgroundColor="{AppThemeBinding Light={StaticResource Info}, Dark={StaticResource Info}}"
                   CornerRadius="12"
                   Padding="16"
                   Margin="0,0,0,8"
                   HasShadow="False"
                   BorderColor="Transparent">
                <Label Text="{Binding StatusMessage}"
                       TextColor="White"
                       FontSize="14"
                       HorizontalOptions="Center" />
            </Frame>

            <!-- Grid Layout: Request senden (links) | Offene Anfragen (rechts) -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                
                <!-- Request senden Card (linke Seite) -->
                <Border Grid.Column="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                        StrokeThickness="1"
                        Padding="0"
                        Shadow="{Shadow Brush={StaticResource Gray400}, Offset='0,4', Radius=12, Opacity=0.15}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    
                    <ScrollView>
                        <VerticalStackLayout Spacing="16" Padding="20">
                            <!-- Card Header -->
                            <Grid ColumnDefinitions="Auto,*">
                                <Border Grid.Column="0"
                                        Background="{StaticResource PrimaryGradient}"
                                        WidthRequest="48"
                                        HeightRequest="48"
                                        StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="📤"
                                           FontSize="24"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                                
                                <VerticalStackLayout Grid.Column="1" Padding="12,0,0,0" VerticalOptions="Center">
                                    <Label Text="Request senden"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                           FontSize="18"
                                           FontAttributes="Bold" />
                                    <Label Text="An deine Freunde"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                           FontSize="11" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Separator -->
                            <BoxView HeightRequest="1"
                                     BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                                     Margin="0,4" />

                            <Button Text="👥 Freunde laden"
                                    Command="{Binding LoadFriendsCommand}"
                                    Background="{StaticResource PrimaryGradient}"
                                    TextColor="White"
                                    CornerRadius="12"
                                    HeightRequest="44"
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    Shadow="{Shadow Brush={StaticResource Primary}, Offset='0,4', Radius=12, Opacity=0.3}" />

                            <Label Text="Freund auswählen"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   Margin="0,4,0,0" />

                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource SurfaceDark}}"
                                    Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                    StrokeThickness="1"
                                    Padding="12,6">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Picker ItemsSource="{Binding Friends}"
                                        ItemDisplayBinding="{Binding Username}"
                                        SelectedItem="{Binding SelectedFriend}"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                        BackgroundColor="Transparent"
                                        FontSize="14"
                                        Title="Wähle einen Freund..." />
                            </Border>

                            <Label Text="Request-Typ"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   Margin="0,4,0,0" />

                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource SurfaceDark}}"
                                    Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                    StrokeThickness="1"
                                    Padding="12,6">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Picker ItemsSource="{Binding RequestTypes}"
                                        SelectedItem="{Binding RequestType}"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                        BackgroundColor="Transparent"
                                        FontSize="14"
                                        Title="Wähle Typ..." />
                            </Border>

                            <Label Text="Nachricht"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   Margin="0,4,0,0" />

                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource SurfaceDark}}"
                                    Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                    StrokeThickness="1"
                                    Padding="12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Editor Text="{Binding RequestMessage}"
                                        Placeholder="Beschreibe deine Anfrage..."
                                        HeightRequest="80"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                        PlaceholderColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                        BackgroundColor="Transparent"
                                        FontSize="14"
                                        AutoSize="TextChanges" />
                            </Border>

                            <Button Text="✉️ Request senden"
                                    Command="{Binding SendRequestCommand}"
                                    Clicked="OnSendRequestClicked"
                                    Background="{StaticResource PrimaryGradient}"
                                    TextColor="White"
                                    CornerRadius="12"
                                    HeightRequest="52"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    Margin="0,8,0,0"
                                    Shadow="{Shadow Brush={StaticResource Primary}, Offset='0,6', Radius=16, Opacity=0.4}" />
                        </VerticalStackLayout>
                    </ScrollView>
                </Border>

                <!-- Offene Anfragen Card (rechte Seite) -->
                <Border Grid.Column="1"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                        StrokeThickness="1"
                        Padding="0"
                        Shadow="{Shadow Brush={StaticResource Gray400}, Offset='0,4', Radius=12, Opacity=0.15}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    
                    <VerticalStackLayout Spacing="16" Padding="20">
                        <!-- Card Header -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource Success}"
                                    WidthRequest="48"
                                    HeightRequest="48"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="📬"
                                       FontSize="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            
                            <VerticalStackLayout Grid.Column="1" Padding="12,0,0,0" VerticalOptions="Center">
                                <Label Text="Offene Anfragen"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                                <Label Text="Warten auf Antwort"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                       FontSize="11" />
                            </VerticalStackLayout>

                            <Button Grid.Column="2"
                                    Text="🔄"
                                    Command="{Binding LoadPendingRequestsCommand}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                    CornerRadius="10"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    FontSize="16"
                                    Padding="0"
                                    VerticalOptions="Center" />
                        </Grid>

                        <!-- Separator -->
                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                                 Margin="0,4" />

                        <!-- Scrollable List -->
                        <ScrollView VerticalOptions="FillAndExpand">
                            <CollectionView ItemsSource="{Binding PendingRequests}">
                                <CollectionView.EmptyView>
                                    <VerticalStackLayout Padding="24" Spacing="12" HorizontalOptions="Center">
                                        <Label Text="✨"
                                               FontSize="48"
                                               HorizontalOptions="Center" />
                                        <Label Text="Keine offenen Anfragen"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center" />
                                        <Label Text="Neue Anfragen erscheinen hier"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                               FontSize="12"
                                               HorizontalOptions="Center"
                                               HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource SurfaceDark}}"
                                                Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Primary}}"
                                                StrokeThickness="2"
                                                Padding="12"
                                                Margin="0,6">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12"/>
                                            </Border.StrokeShape>
                                            
                                            <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                                <!-- Hauptbereich: Avatar+Info links, Nachricht rechts -->
                                                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                    <!-- Linke Seite: Avatar + User Info -->
                                                    <VerticalStackLayout Grid.Column="0" Spacing="8">
                                                        <Border StrokeThickness="2"
                                                                Stroke="{StaticResource Success}"
                                                                WidthRequest="64"
                                                                HeightRequest="64">
                                                            <Border.StrokeShape>
                                                                <RoundRectangle CornerRadius="32"/>
                                                            </Border.StrokeShape>
                                                            <Image Source="{Binding SenderAvatarUrl}"
                                                                   Aspect="AspectFill" />
                                                        </Border>

                                                        <Label Text="{Binding SenderUsername}"
                                                               TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                                               FontAttributes="Bold"
                                                               FontSize="15"
                                                               HorizontalOptions="Center" />
                                                        
                                                        <Border BackgroundColor="{StaticResource Primary}"
                                                                Padding="6,3"
                                                                HorizontalOptions="Center">
                                                            <Border.StrokeShape>
                                                                <RoundRectangle CornerRadius="5"/>
                                                            </Border.StrokeShape>
                                                            <Label Text="{Binding RequestType}"
                                                                   TextColor="White"
                                                                   FontSize="10"
                                                                   FontAttributes="Bold" />
                                                        </Border>
                                                        
                                                        <Label Text="{Binding CreatedAt, StringFormat='📅 {0:dd.MM HH:mm}'}"
                                                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                                               FontSize="10"
                                                               HorizontalOptions="Center" />
                                                    </VerticalStackLayout>

                                                    <!-- Rechte Seite: Großes Nachricht-Textfeld -->
                                                    <Border Grid.Column="1"
                                                            BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                                                            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                                            StrokeThickness="1"
                                                            Padding="12"
                                                            VerticalOptions="Fill">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="10"/>
                                                        </Border.StrokeShape>
                                                        <ScrollView>
                                                            <Label Text="{Binding Message}"
                                                                   TextColor="{AppThemeBinding Light={StaticResource Gray800}, Dark={StaticResource Gray200}}"
                                                                   FontSize="14"
                                                                   LineBreakMode="WordWrap" />
                                                        </ScrollView>
                                                    </Border>
                                                </Grid>

                                                <!-- Action Buttons -->
                                                <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,4,0,0">
                                                    <Button Grid.Column="0"
                                                            Text="✓ Accept"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AcceptRequestCommand}"
                                                            CommandParameter="{Binding .}"
                                                            Background="{StaticResource SuccessGradient}"
                                                            TextColor="White"
                                                            HeightRequest="44"
                                                            CornerRadius="10"
                                                            FontSize="14"
                                                            FontAttributes="Bold"
                                                            Shadow="{Shadow Brush={StaticResource Success}, Offset='0,3', Radius=8, Opacity=0.4}" />
                                                    <Button Grid.Column="1"
                                                            Text="✗ Decline"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeclineRequestCommand}"
                                                            CommandParameter="{Binding .}"
                                                            Background="{StaticResource DangerGradient}"
                                                            TextColor="White"
                                                            HeightRequest="44"
                                                            CornerRadius="10"
                                                            FontSize="14"
                                                            FontAttributes="Bold"
                                                            Shadow="{Shadow Brush={StaticResource Danger}, Offset='0,3', Radius=8, Opacity=0.4}" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </ScrollView>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Gesendete Requests (volle Breite unten) -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                    StrokeThickness="1"
                    Padding="0"
                    Shadow="{Shadow Brush={StaticResource Gray400}, Offset='0,4', Radius=12, Opacity=0.15}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                
                <VerticalStackLayout Spacing="16" Padding="20">
                    <!-- Card Header -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource Info}"
                                WidthRequest="48"
                                HeightRequest="48"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label Text="📨"
                                   FontSize="24"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        
                        <VerticalStackLayout Grid.Column="1" Padding="12,0,0,0" VerticalOptions="Center">
                            <Label Text="Gesendete Requests"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                   FontSize="20"
                                   FontAttributes="Bold" />
                            <Label Text="Deine versendeten Anfragen"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                   FontSize="12" />
                        </VerticalStackLayout>

                        <Button Grid.Column="2"
                                Text="🔄"
                                Command="{Binding LoadSentRequestsCommand}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"
                                TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                CornerRadius="10"
                                WidthRequest="44"
                                HeightRequest="44"
                                FontSize="18"
                                VerticalOptions="Center" />
                    </Grid>

                    <!-- Separator -->
                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                             Margin="0,8" />

                    <CollectionView ItemsSource="{Binding SentRequests}">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout Padding="24" Spacing="12" HorizontalOptions="Center">
                                <Label Text="📭"
                                       FontSize="48"
                                       HorizontalOptions="Center" />
                                <Label Text="Keine gesendeten Requests"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center" />
                                <Label Text="Sende deinen ersten Request an einen Freund"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                       FontSize="13"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource SurfaceDark}}"
                                        Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                        StrokeThickness="1"
                                        Padding="16"
                                        Margin="0,8">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    
                                    <Grid ColumnDefinitions="64,*,Auto">
                                        <!-- Avatar -->
                                        <Border Grid.Column="0"
                                                StrokeThickness="2"
                                                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                                WidthRequest="64"
                                                HeightRequest="64">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="32"/>
                                            </Border.StrokeShape>
                                            <Image Source="{Binding ReceiverAvatarUrl}"
                                                   Aspect="AspectFill" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Padding="12,0" Spacing="4" VerticalOptions="Center">
                                            <Label Text="{Binding ReceiverUsername}"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                                   FontAttributes="Bold"
                                                   FontSize="17" />
                                            
                                            <Border BackgroundColor="{StaticResource Info}"
                                                    Padding="8,4"
                                                    HorizontalOptions="Start">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="6"/>
                                                </Border.StrokeShape>
                                                <Label Text="{Binding RequestType}"
                                                       TextColor="White"
                                                       FontSize="12"
                                                       FontAttributes="Bold" />
                                            </Border>
                                            
                                            <Label Text="{Binding Message}"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                                   FontSize="14"
                                                   LineBreakMode="WordWrap"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>

                                        <!-- Status Badge -->
                                        <Border Grid.Column="2"
                                                VerticalOptions="Start"
                                                Padding="10,6"
                                                Margin="0,8,0,0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="8"/>
                                            </Border.StrokeShape>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Pending">
                                                    <Setter Property="BackgroundColor" Value="{StaticResource Warning}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Accepted">
                                                    <Setter Property="BackgroundColor" Value="{StaticResource Success}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Declined">
                                                    <Setter Property="BackgroundColor" Value="{StaticResource Danger}" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="{Binding Status}"
                                                   TextColor="White"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Bottom Spacing -->
            <BoxView HeightRequest="20" BackgroundColor="Transparent" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>