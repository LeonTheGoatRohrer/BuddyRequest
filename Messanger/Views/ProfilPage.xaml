<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Messanger.Views.ProfilPage"
             Title="Profil"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource BackgroundDark}}">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="20">
            
            <!-- Profile Header with Gradient -->
            <Border BackgroundColor="Transparent"
                    StrokeThickness="0"
                    Padding="0"
                    Margin="0,0,0,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4F46E5" Offset="0.0" />
                        <GradientStop Color="#7C3AED" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource Primary}" 
                            Offset="0,8" 
                            Radius="24" 
                            Opacity="0.4" />
                </Border.Shadow>
                
                <VerticalStackLayout Padding="32,40,32,32" Spacing="16">
                    <!-- Avatar with Ring -->
                    <Grid WidthRequest="140" HeightRequest="140" HorizontalOptions="Center">
                        <!-- Outer Ring -->
                        <Border StrokeThickness="4" 
                                Stroke="White" 
                                WidthRequest="140" 
                                HeightRequest="140"
                                HorizontalOptions="Center"
                                BackgroundColor="Transparent">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="70"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.2" />
                            </Border.Shadow>
                        </Border>
                        
                        <!-- Avatar Image -->
                        <Border StrokeThickness="0" 
                                WidthRequest="128" 
                                HeightRequest="128"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="64"/>
                            </Border.StrokeShape>
                            <Image Source="{Binding AvatarUrl}" Aspect="AspectFill" />
                        </Border>
                    </Grid>

                    <Label Text="{Binding Username}"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    
                    <Button Text="🎨 Profilbild ändern" 
                            Command="{Binding ChangeAvatarCommand}" 
                            BackgroundColor="#FFFFFF30" 
                            TextColor="White" 
                            CornerRadius="12" 
                            HeightRequest="44"
                            FontSize="14"
                            FontAttributes="Bold"
                            Margin="0" />
                </VerticalStackLayout>
            </Border>

            <!-- Profile Settings Card -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                    StrokeThickness="1"
                    Padding="20"
                    Shadow="{Shadow Brush={StaticResource Gray400}, Offset='0,4', Radius=12, Opacity=0.15}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                
                <VerticalStackLayout Spacing="20">
                    <!-- Card Header -->
                    <Label Text="⚙️ Profil bearbeiten"
                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                           FontSize="20"
                           FontAttributes="Bold" />

                    <!-- Separator -->
                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                             Margin="0,0,0,8" />
                    
                    <!-- Username Field -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Benutzername" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource SurfaceDark}}"
                                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                StrokeThickness="1"
                                Padding="16,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Entry Text="{Binding Username}" 
                                   Placeholder="Benutzername"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                   PlaceholderColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                   BackgroundColor="Transparent"
                                   FontSize="15" />
                        </Border>
                    </VerticalStackLayout>
                    
                    <!-- Email Field -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="E-Mail" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource SurfaceDark}}"
                                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                StrokeThickness="1"
                                Padding="16,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Entry Text="{Binding Email}" 
                                   Placeholder="E-Mail" 
                                   Keyboard="Email"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                   PlaceholderColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                   BackgroundColor="Transparent"
                                   FontSize="15" />
                        </Border>
                    </VerticalStackLayout>

                    <Button Text="💾 Profil speichern" 
                            Command="{Binding SaveProfileCommand}" 
                            Background="{StaticResource PrimaryGradient}"
                            TextColor="White" 
                            CornerRadius="12" 
                            HeightRequest="52"
                            FontSize="16"
                            FontAttributes="Bold"
                            Shadow="{Shadow Brush={StaticResource Primary}, Offset='0,4', Radius=12, Opacity=0.3}" />
                </VerticalStackLayout>
            </Border>
            
            <!-- Bio Card -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                    StrokeThickness="1"
                    Padding="20"
                    Shadow="{Shadow Brush={StaticResource Gray400}, Offset='0,4', Radius=12, Opacity=0.15}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                
                <VerticalStackLayout Spacing="16">
                    <!-- Card Header -->
                    <Label Text="📝 Über mich"
                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                           FontSize="20"
                           FontAttributes="Bold" />

                    <!-- Separator -->
                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                             Margin="0,0,0,8" />

                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource SurfaceDark}}"
                            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                            StrokeThickness="1"
                            Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Editor Text="{Binding Bio}" 
                                AutoSize="TextChanges" 
                                MinimumHeightRequest="120"
                                Placeholder="Erzähle etwas über dich..."
                                TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                PlaceholderColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                BackgroundColor="Transparent"
                                FontSize="15" />
                    </Border>
                    
                    <Button Text="💾 Bio speichern" 
                            Command="{Binding SaveBioCommand}" 
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="White" 
                            CornerRadius="12" 
                            HeightRequest="48"
                            FontSize="15"
                            FontAttributes="Bold"
                            Shadow="{Shadow Brush={StaticResource Secondary}, Offset='0,3', Radius=10, Opacity=0.3}" />
                </VerticalStackLayout>
            </Border>

            <!-- Status Message -->
            <Border IsVisible="{Binding Message, Converter={StaticResource StringToBoolConverter}}"
                    BackgroundColor="{StaticResource Success}"
                    StrokeThickness="0"
                    Padding="16"
                    Margin="0,0,0,8">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Label Text="{Binding Message}" 
                       TextColor="White" 
                       HorizontalOptions="Center" 
                       FontSize="14"
                       FontAttributes="Bold" />
            </Border>
            
            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" 
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               WidthRequest="40"
                               HeightRequest="40"
                               HorizontalOptions="Center" />
            
            <!-- Logout Button -->
            <Button Text="🚪 Abmelden" 
                    Command="{Binding LogoutCommand}" 
                    Background="{StaticResource DangerGradient}"
                    TextColor="White" 
                    CornerRadius="12" 
                    HeightRequest="52"
                    FontSize="16"
                    FontAttributes="Bold"
                    Margin="0,8,0,0"
                    Shadow="{Shadow Brush={StaticResource Danger}, Offset='0,4', Radius=12, Opacity=0.3}" />

            <!-- Bottom Spacing -->
            <BoxView HeightRequest="20" BackgroundColor="Transparent" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
