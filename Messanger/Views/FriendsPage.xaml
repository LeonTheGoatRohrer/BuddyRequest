<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Messanger.Views.FriendsPage"
             Title="Freunde"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource BackgroundDark}}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Header -->
            <Grid RowDefinitions="Auto,Auto" Padding="8,16">
                <Label Grid.Row="0"
                       Text="👥 Freunde"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                       HorizontalOptions="Start" />
                <Label Grid.Row="1"
                       Text="Verwalte deine Kontakte und finde neue Freunde"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                       HorizontalOptions="Start"
                       Margin="0,4,0,0" />
            </Grid>

            <!-- Suchbereich Card -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                    StrokeThickness="1"
                    Padding="20"
                    Shadow="{Shadow Brush={StaticResource Gray400}, Offset='0,4', Radius=12, Opacity=0.15}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                
                <VerticalStackLayout Spacing="16">
                    <!-- Card Header -->
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource Info}"
                                WidthRequest="48"
                                HeightRequest="48"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label Text="🔍"
                                   FontSize="24"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        
                        <VerticalStackLayout Grid.Column="1" Padding="12,0,0,0" VerticalOptions="Center">
                            <Label Text="Freunde suchen"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                   FontSize="20"
                                   FontAttributes="Bold" />
                            <Label Text="Suche nach Username oder Key"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                   FontSize="12" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Separator -->
                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                             Margin="0,4" />

                    <!-- Search Input -->
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource SurfaceDark}}"
                            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                            StrokeThickness="1"
                            Padding="16,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Entry Placeholder="Username oder Key eingeben"
                               Text="{Binding SearchQuery}"
                               TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                               PlaceholderColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                               BackgroundColor="Transparent"
                               FontSize="15" />
                    </Border>
            
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Grid.Column="0"
                                Text="🔍 Suchen"
                                Command="{Binding SearchCommand}"
                                Background="{StaticResource PrimaryGradient}"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="48"
                                FontSize="15"
                                FontAttributes="Bold"
                                Shadow="{Shadow Brush={StaticResource Primary}, Offset='0,4', Radius=12, Opacity=0.3}" />
                        
                        <Button Grid.Column="1"
                                Text="📋 Alle anzeigen"
                                Command="{Binding ShowAllUsersCommand}"
                                Background="{StaticResource SuccessGradient}"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="48"
                                FontSize="15"
                                FontAttributes="Bold"
                                Shadow="{Shadow Brush={StaticResource Success}, Offset='0,4', Radius=12, Opacity=0.3}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Suchergebnisse -->
            <VerticalStackLayout Spacing="12" IsVisible="{Binding HasSearchResults}">
                <Label Text="🎯 Suchergebnisse"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                       Margin="8,8,8,0" />

                <CollectionView ItemsSource="{Binding SearchResults}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                                    StrokeThickness="1"
                                    Padding="16"
                                    Margin="0,6"
                                    Shadow="{Shadow Brush={StaticResource Gray400}, Offset='0,2', Radius=8, Opacity=0.1}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                
                                <Grid ColumnDefinitions="64,*,Auto" ColumnSpacing="12">
                                    <!-- Avatar -->
                                    <Border Grid.Column="0" 
                                            StrokeThickness="3"
                                            Stroke="{StaticResource Info}"
                                            WidthRequest="64"
                                            HeightRequest="64">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="32"/>
                                        </Border.StrokeShape>
                                        <Image Source="{Binding Avatar}" 
                                               Aspect="AspectFill"/>
                                    </Border>
                                    
                                    <!-- User Info -->
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                        <Label Text="{Binding Username}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                                        <Label Text="{Binding Key}"
                                               FontSize="13"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                        <Label Text="{Binding Email}"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray500}}" />
                                    </VerticalStackLayout>
                                    
                                    <!-- Action Button -->
                                    <Border Grid.Column="2"
                                            VerticalOptions="Center"
                                            Padding="0"
                                            StrokeThickness="0">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding RequestSent}" Value="False">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding RequestSent}" Value="True">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Button Text="➕"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SendRequestCommand}"
                                                CommandParameter="{Binding .}"
                                                Background="{StaticResource PrimaryGradient}"
                                                TextColor="White"
                                                CornerRadius="12"
                                                WidthRequest="48"
                                                HeightRequest="48"
                                                FontSize="20"
                                                Padding="0" />
                                    </Border>
                                    
                                    <Border Grid.Column="2"
                                            VerticalOptions="Center"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"
                                            Padding="12,8"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding RequestSent}" Value="False">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding RequestSent}" Value="True">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="✅ Gesendet"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                                               FontSize="12"
                                               FontAttributes="Bold" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Meine Freunde -->
            <VerticalStackLayout Spacing="12">
                <Grid ColumnDefinitions="*,Auto" Margin="8,16,8,0">
                    <Label Grid.Column="0"
                           Text="🤝 Meine Freunde"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                           VerticalOptions="Center" />

                    <Button Grid.Column="1"
                            Text="🔄"
                            Command="{Binding LoadFriendsCommand}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"
                            TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                            CornerRadius="10"
                            WidthRequest="44"
                            HeightRequest="44"
                            FontSize="18"
                            VerticalOptions="Center" />
                </Grid>

                <CollectionView ItemsSource="{Binding Friends}">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="32" Spacing="12" HorizontalOptions="Center">
                            <Label Text="😔"
                                   FontSize="48"
                                   HorizontalOptions="Center" />
                            <Label Text="Noch keine Freunde"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                            <Label Text="Suche nach Leuten und sende Freundschaftsanfragen"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                   FontSize="13"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                                    Stroke="{StaticResource Success}"
                                    StrokeThickness="2"
                                    Padding="16"
                                    Margin="0,6"
                                    Shadow="{Shadow Brush={StaticResource Success}, Offset='0,3', Radius=10, Opacity=0.15}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                
                                <Grid ColumnDefinitions="60,*,Auto" ColumnSpacing="12">
                                    <!-- Avatar -->
                                    <Border Grid.Column="0" 
                                            StrokeThickness="3"
                                            Stroke="{StaticResource Success}"
                                            WidthRequest="60"
                                            HeightRequest="60">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="30"/>
                                        </Border.StrokeShape>
                                        <Image Source="{Binding Avatar}" 
                                               Aspect="AspectFill"/>
                                    </Border>
                                    
                                    <!-- User Info -->
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                        <Label Text="{Binding Username}"
                                               FontSize="17"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                                        <Label Text="{Binding Key}"
                                               FontSize="13"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                    </VerticalStackLayout>

                                    <!-- Chat Button -->
                                    <Button Grid.Column="2"
                                            Text="💬"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenChatCommand}"
                                            CommandParameter="{Binding .}"
                                            VerticalOptions="Center"
                                            Background="{StaticResource PrimaryGradient}"
                                            TextColor="White"
                                            CornerRadius="12"
                                            WidthRequest="48"
                                            HeightRequest="48"
                                            FontSize="20"
                                            Shadow="{Shadow Brush={StaticResource Primary}, Offset='0,3', Radius=10, Opacity=0.3}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- Bottom Spacing -->
            <BoxView HeightRequest="20" BackgroundColor="Transparent" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
