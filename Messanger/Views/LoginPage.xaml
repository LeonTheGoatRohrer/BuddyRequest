<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:Messanger.Helpers"
             x:Class="Messanger.Views.LoginPage"
             Title="{helpers:Translate Key=Login_Title}"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- App Logo / Avatar -->
            <Border StrokeThickness="0"
                    WidthRequest="100"
                    HeightRequest="100"
                    HorizontalOptions="Center"
                    Margin="0,20,0,10"
                    BackgroundColor="#007AFF">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="50"/>
                </Border.StrokeShape>
                <Label Text="👋" 
                       FontSize="48" 
                       HorizontalOptions="Center" 
                       VerticalOptions="Center"/>
            </Border>

            <Label Text="{helpers:Translate Key=Login_Title}"
                   FontSize="24"
                   HorizontalOptions="Center"
                   Margin="0,0,0,10"
                   TextColor="{DynamicResource TextColor}" />

            <Label Text="{helpers:Translate Key=Login_Username}"
                   TextColor="{DynamicResource TextColor}" />
            <Entry Placeholder="{helpers:Translate Key=Login_Username}"
                   Text="{Binding Username}"
                   TextColor="{DynamicResource TextColor}"
                   PlaceholderColor="{DynamicResource TextColorSecondary}"
                   BackgroundColor="{DynamicResource SurfaceColor}" />

            <Label Text="{helpers:Translate Key=Login_Password}"
                   TextColor="{DynamicResource TextColor}" />
            <Entry Placeholder="{helpers:Translate Key=Login_Password}"
                   IsPassword="True"
                   Text="{Binding Password}"
                   TextColor="{DynamicResource TextColor}"
                   PlaceholderColor="{DynamicResource TextColorSecondary}"
                   BackgroundColor="{DynamicResource SurfaceColor}" />

            <Label Text="{Binding Message}"
                   TextColor="Red" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}" />

            <Button Text="{helpers:Translate Key=Login_Button}"
                    Command="{Binding LoginCommand}"
                    BackgroundColor="#007AFF"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50" />

            <Label Text="{helpers:Translate Key=Login_DemoLogin}" 
                   FontSize="14" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   Margin="0,10,0,5"
                   TextColor="{DynamicResource TextColor}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="LeonROhrer"
                        Command="{Binding DemoLoginCommand}"
                        BackgroundColor="#34C759"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="50" />
                
                <Button Grid.Column="1"
                        Text="FranzSepp"
                        Command="{Binding DemoLoginFranzCommand}"
                        BackgroundColor="#FF9500"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="50" />
            </Grid>

            <Button Text="{helpers:Translate Key=Login_Register}"
                    Clicked="OnRegisterClicked"
                    Margin="0,10,0,0"
                    BackgroundColor="Transparent"
                    TextColor="#007AFF" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
