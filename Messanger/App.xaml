<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Messanger"
             xmlns:converters="clr-namespace:Messanger.Converters"
             x:Class="Messanger.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:StringToBoolConverter x:Key="StringToBoolConverter" />

            <!-- Theme Colors - Updated to match modern design -->
            <Color x:Key="BackgroundColor">#F9FAFB</Color>
            <Color x:Key="SurfaceColor">#F3F4F6</Color>
            <Color x:Key="TextColor">#111827</Color>
            <Color x:Key="TextColorSecondary">#6B7280</Color>
            <Color x:Key="BorderColor">#E5E7EB</Color>
            <Color x:Key="PrimaryColor">#6366F1</Color>
            <Color x:Key="SecondaryColor">#8B5CF6</Color>
            <Color x:Key="CardColor">#FFFFFF</Color>
            <Color x:Key="ButtonTextColor">#FFFFFF</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
